PROJECT_NAME=Keyzone CRM API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=realestate
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# Async URL is built from the values above; override only if needed
DATABASE_URL=postgresql+asyncpg://admin:admin@postgres:5432/realestate
SYNC_DATABASE_URL=postgresql+psycopg2://admin:admin@postgres:5432/realestate

BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:8080","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3002"]
EMAIL_DOMAIN=keyzonestates.tn
